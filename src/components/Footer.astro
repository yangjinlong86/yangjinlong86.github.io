---
import { socialMedia } from '../consts';
const year = new Date().getFullYear();
---
<footer>
  <div class="copyright">
    © {year} yangjinlong86.github.io • Powered by
    <a href="https://www.astro.build/" target="_blank" rel="noopener noreferrer">Astro</a>
  </div>
  <div class="social-links">
    {socialMedia.map((item) => (
      <a href={item.href} target="_blank" rel="noopener noreferrer" aria-label={item.icon}>
        <i class={`iconfont icon-${item.icon}`}></i>
      </a>
    ))}
  </div>
</footer>

<style>
  footer {
    padding: 2em 1em 4em;
    background: linear-gradient(var(--gray-gradient)) no-repeat;
    color: rgb(var(--gray));
    text-align: center;
  }
  .copyright a { color: rgb(var(--gray)); }
  .copyright a:hover { color: var(--accent); }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1em;
    margin-top: 1em;
  }
  .social-links a { color: rgb(var(--gray)); text-decoration: none; }
  .social-links a:hover { color: var(--accent); }
  .social-links .iconfont { font-size: 1.2rem; }
</style>
