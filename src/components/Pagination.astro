---
interface Props { currentPage: number; totalPage: number; prefix: string; }
const { currentPage, totalPage, prefix } = Astro.props;
---
<div class="button-wrapper">
  {currentPage - 1 > 0 && (
    <a href={prefix + (currentPage - 1 === 1 ? '' : currentPage - 1)} rel="prev">
      <button class="page-button">上一页</button>
    </a>
  )}
  <div>{`${currentPage} / ${totalPage}`}</div>
  {currentPage + 1 <= totalPage && (
    <a href={prefix + (currentPage + 1)} rel="next">
      <button class="page-button">下一页</button>
    </a>
  )}
</div>
