---
interface Props { currentPage: number; totalPage: number; prefix: string; }
const { currentPage, totalPage, prefix } = Astro.props;
---
<nav class="pagination">
  {currentPage - 1 > 0 && (
    <a href={prefix + (currentPage - 1 === 1 ? '' : currentPage - 1)} rel="prev">← 上一页</a>
  )}
  <span class="current">{currentPage} / {totalPage}</span>
  {currentPage + 1 <= totalPage && (
    <a href={prefix + (currentPage + 1)} rel="next">下一页 →</a>
  )}
</nav>
